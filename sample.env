# Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Drive: або API key (публічні папки), або OAuth (коли key блокують методи Get/List)
# https://console.cloud.google.com — увімкніть "Google Drive API"
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key_here
# OAuth: шлях до JSON «Desktop» OAuth client, токен збережеться в GOOGLE_DRIVE_OAUTH_TOKEN
# GOOGLE_DRIVE_OAUTH_CLIENT_SECRETS=/path/to/client_secret_....json
# GOOGLE_DRIVE_OAUTH_TOKEN=data/drive_oauth_token.json

# Модель за замовчуванням (можна перевизначити через --model)
DEFAULT_MODEL=gemini-2.0-flash-lite
